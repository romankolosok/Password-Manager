<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PasswordManager.App.Views.ForgotPasswordView"
        Title="Crypty - Reset Password" Height="340" Width="440"
        Background="White" WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel Width="320" Margin="32,28" HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="Reset Password" HorizontalAlignment="Left" FontSize="26" FontWeight="Bold"
                       Foreground="#111827" Margin="0,0,0,4"/>
            <TextBlock Text="Enter your email to receive a recovery code"
                       HorizontalAlignment="Left" FontSize="13" Foreground="#6B7280" Margin="0,0,0,28"/>

            <!-- Email -->
            <TextBlock Text="Email" FontSize="14" Foreground="#374151" Margin="0,0,0,6"/>
            <Border Classes="input-border" Margin="0,0,0,16">
                <Grid ColumnDefinitions="Auto,*">
                    <Viewbox Grid.Column="0" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Path Fill="Transparent" Stroke="#9CA3AF" StrokeThickness="1.5" StrokeJoin="Round" StrokeLineCap="Round"
                              Data="M 4,9 L 10.2,13.65 C 11.27,14.45 12.73,14.45 13.8,13.65 L 20,9 M 3,9.18 C 3,8.45 3.39,7.78 4.03,7.43 L 11.03,3.54 C 11.63,3.2 12.37,3.2 12.97,3.54 L 19.97,7.43 C 20.61,7.78 21,8.45 21,9.18 V 17 C 21,18.1 20.1,19 19,19 H 5 C 3.9,19 3,18.1 3,17 V 9.18 Z"/>
                    </Viewbox>
                    <TextBox Grid.Column="1" Classes="inner-input"
                             Watermark="Enter your email"
                             Text="{Binding Email}"/>
                </Grid>
            </Border>

            <!-- Validation or server error -->
            <TextBlock Text="{Binding DisplayError}" Foreground="#C42B1C" FontSize="12" TextWrapping="Wrap"
                       Margin="0,0,0,16" IsVisible="{Binding DisplayErrorVisible}"/>

            <!-- Send recovery email -->
            <Button Height="44" Command="{Binding SendRecoveryEmailCommand}" Classes="primary"
                    HorizontalAlignment="Stretch">
                <Grid>
                    <TextBlock Text="Send recovery email" VerticalAlignment="Center"
                               HorizontalAlignment="Center" IsVisible="{Binding !IsLoading}"/>
                    <Panel IsVisible="{Binding IsLoading}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Width="28" Height="28" Stroke="White" StrokeThickness="4" Fill="Transparent"
                                 StrokeDashArray="2,3" StrokeLineCap="Round"
                                 RenderTransformOrigin="50%,50%">
                            <Ellipse.RenderTransform>
                                <RotateTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Styles>
                                <Style Selector="Ellipse">
                                    <Style.Animations>
                                        <Animation Duration="0:0:0.8" IterationCount="INFINITE">
                                            <KeyFrame Cue="0%">
                                                <Setter Property="RotateTransform.Angle" Value="0"/>
                                            </KeyFrame>
                                            <KeyFrame Cue="100%">
                                                <Setter Property="RotateTransform.Angle" Value="360"/>
                                            </KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                            </Ellipse.Styles>
                        </Ellipse>
                    </Panel>
                </Grid>
            </Button>

            <Button Content="&#x2190; Back to Login" Cursor="Hand" Height="44" FontSize="14" FontWeight="SemiBold"
                    Foreground="#374151" Margin="0,20,0,0" Click="BackToLogin_Click"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Classes="icon-btn"/>
        </StackPanel>
    </Grid>
</Window>

