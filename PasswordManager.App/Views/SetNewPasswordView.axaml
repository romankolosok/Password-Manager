<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PasswordManager.App.Views.SetNewPasswordView"
        Title="Crypty - Reset Password" Height="680" Width="440"
        Background="White" WindowStartupLocation="CenterScreen">
    <Grid>
        <StackPanel Width="320" Margin="40,28" HorizontalAlignment="Center" VerticalAlignment="Center">

            <TextBlock Text="Set New Password" HorizontalAlignment="Left" FontSize="26" FontWeight="Bold"
                       Foreground="#111827" Margin="0,0,0,4"/>
            <TextBlock Text="Create a new master password for your account" HorizontalAlignment="Left"
                       FontSize="13" Foreground="#6B7280" Margin="0,0,0,28"/>

            <!-- Email -->
            <TextBlock Text="Email" FontSize="14" Foreground="#374151" Margin="0,0,0,6"/>
            <Border Classes="input-border" Margin="0,0,0,4">
                <TextBox Classes="inner-input"
                         Text="{Binding Email}"
                         IsReadOnly="True"
                         Cursor="Arrow"/>
            </Border>
            <TextBlock Text="This email cannot be changed" FontSize="12" Foreground="#6B7280"
                       Margin="0,0,0,16" HorizontalAlignment="Left"/>

            <!-- Recovery Key -->
            <TextBlock Text="Recovery Key" FontSize="14" Foreground="#374151" Margin="0,0,0,6"/>
            <Border Classes="input-border" Margin="0,0,0,4">
                <TextBox Classes="inner-input"
                         Text="{Binding RecoveryKey}"
                         Watermark="Paste your recovery key (base64)"/>
            </Border>
            <TextBlock Text="You received this when you created your account" FontSize="12" Foreground="#6B7280"
                       Margin="0,0,0,16" HorizontalAlignment="Left"/>

            <!-- New Master Password -->
            <TextBlock Text="New Master Password" FontSize="14" Foreground="#374151" Margin="0,0,0,6"/>
            <Border Classes="input-border" Margin="0,0,0,8">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Viewbox Grid.Column="0" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Path Data="M12,2 C9.24,2 7,4.24 7,7 L7,9 L5,9 C3.9,9 3,9.9 3,11 L3,20 C3,21.1 3.9,22 5,22 L19,22 C20.1,22 21,21.1 21,20 L21,11 C21,9.9 20.1,9 19,9 L17,9 L17,7 C17,4.24 14.76,2 12,2 Z M12,4 C13.66,4 15,5.34 15,7 L15,9 L9,9 L9,7 C9,5.34 10.34,4 12,4 Z"
                              Fill="#9CA3AF" Stroke="#9CA3AF" StrokeThickness="0.5"/>
                    </Viewbox>
                    <TextBox Grid.Column="1" Classes="inner-input"
                             PasswordChar="&#x2022;"
                             RevealPassword="{Binding IsPasswordVisible}"
                             Text="{Binding NewMasterPassword}"
                             Watermark="Create a new master password"/>
                    <ToggleButton Grid.Column="2" Classes="peek"
                                  IsChecked="{Binding IsPasswordVisible}"
                                  ToolTip.Tip="Show Password">
                        <Panel>
                            <Viewbox Width="20" Height="20" IsVisible="{Binding !IsPasswordVisible}">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="#374151" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                          Data="M1,12 C1,12 5,4 12,4 C19,4 23,12 23,12"/>
                                    <Path Stroke="#374151" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                          Data="M1,12 C1,12 5,20 12,20 C19,20 23,12 23,12"/>
                                    <Ellipse Canvas.Left="9" Canvas.Top="9" Width="6" Height="6" Stroke="#374151" StrokeThickness="2" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                            <Viewbox Width="20" Height="20" IsVisible="{Binding IsPasswordVisible}">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="#374151" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                          Data="M2,2 L22,22"/>
                                    <Path Stroke="#374151" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                          Data="M6.71,6.72 C3.66,8.8 2,12 2,12 C2,12 5.64,19 12,19 C14.05,19 15.82,18.27 17.27,17.29 M11,5.06 C11.33,5.02 11.66,5 12,5 C18.36,5 22,12 22,12 C22,12 21.31,13.33 20,14.83"/>
                                    <Path Stroke="#374151" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                          Data="M14,14.24 C13.47,14.71 12.77,15 12,15 C10.34,15 9,13.66 9,12 C9,11.18 9.33,10.43 9.87,9.89"/>
                                </Canvas>
                            </Viewbox>
                        </Panel>
                    </ToggleButton>
                </Grid>
            </Border>

            <TextBlock Text="" FontSize="12" Foreground="#6B7280" Margin="0,0,0,16" HorizontalAlignment="Left"/>

            <!-- Confirm Master Password -->
            <TextBlock Text="Confirm Master Password" FontSize="14" Foreground="#374151" Margin="0,0,0,6"/>
            <Border Classes="input-border" Margin="0,0,0,8">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <Viewbox Grid.Column="0" Width="20" Height="20" Margin="0,0,10,0" VerticalAlignment="Center">
                        <Path Data="M12,2 C9.24,2 7,4.24 7,7 L7,9 L5,9 C3.9,9 3,9.9 3,11 L3,20 C3,21.1 3.9,22 5,22 L19,22 C20.1,22 21,21.1 21,20 L21,11 C21,9.9 20.1,9 19,9 L17,9 L17,7 C17,4.24 14.76,2 12,2 Z M12,4 C13.66,4 15,5.34 15,7 L15,9 L9,9 L9,7 C9,5.34 10.34,4 12,4 Z"
                              Fill="#9CA3AF" Stroke="#9CA3AF" StrokeThickness="0.5"/>
                    </Viewbox>
                    <TextBox Grid.Column="1" Classes="inner-input"
                             PasswordChar="&#x2022;"
                             RevealPassword="{Binding IsConfirmPasswordVisible}"
                             Text="{Binding ConfirmMasterPassword}"
                             Watermark="Confirm your new master password"/>
                    <ToggleButton Grid.Column="2" Classes="peek"
                                  IsChecked="{Binding IsConfirmPasswordVisible}"
                                  ToolTip.Tip="Show Password">
                        <Panel>
                            <Viewbox Width="20" Height="20" IsVisible="{Binding !IsConfirmPasswordVisible}">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="#374151" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                          Data="M1,12 C1,12 5,4 12,4 C19,4 23,12 23,12"/>
                                    <Path Stroke="#374151" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                          Data="M1,12 C1,12 5,20 12,20 C19,20 23,12 23,12"/>
                                    <Ellipse Canvas.Left="9" Canvas.Top="9" Width="6" Height="6" Stroke="#374151" StrokeThickness="2" Fill="Transparent"/>
                                </Canvas>
                            </Viewbox>
                            <Viewbox Width="20" Height="20" IsVisible="{Binding IsConfirmPasswordVisible}">
                                <Canvas Width="24" Height="24">
                                    <Path Stroke="#374151" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                          Data="M2,2 L22,22"/>
                                    <Path Stroke="#374151" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                          Data="M6.71,6.72 C3.66,8.8 2,12 2,12 C2,12 5.64,19 12,19 C14.05,19 15.82,18.27 17.27,17.29 M11,5.06 C11.33,5.02 11.66,5 12,5 C18.36,5 22,12 22,12 C22,12 21.31,13.33 20,14.83"/>
                                    <Path Stroke="#374151" StrokeThickness="2" StrokeLineCap="Round" StrokeJoin="Round" Fill="Transparent"
                                          Data="M14,14.24 C13.47,14.71 12.77,15 12,15 C10.34,15 9,13.66 9,12 C9,11.18 9.33,10.43 9.87,9.89"/>
                                </Canvas>
                            </Viewbox>
                        </Panel>
                    </ToggleButton>
                </Grid>
            </Border>

            <TextBlock Text="{Binding DisplayError}" Foreground="#C42B1C" FontSize="12" TextWrapping="Wrap" Margin="0,0,0,16"
                       IsVisible="{Binding DisplayErrorVisible}"/>

            <Button Height="44" Command="{Binding ResetPasswordCommand}" Classes="primary" HorizontalAlignment="Stretch" Margin="0,4,0,0">
                <Grid>
                    <TextBlock Text="Reset Password" VerticalAlignment="Center" HorizontalAlignment="Center" IsVisible="{Binding !IsLoading}"/>
                    <Panel IsVisible="{Binding IsLoading}" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <Ellipse Width="28" Height="28" Stroke="White" StrokeThickness="4" Fill="Transparent"
                                 StrokeDashArray="2,3" StrokeLineCap="Round"
                                 RenderTransformOrigin="50%,50%">
                            <Ellipse.RenderTransform>
                                <RotateTransform/>
                            </Ellipse.RenderTransform>
                            <Ellipse.Styles>
                                <Style Selector="Ellipse">
                                    <Style.Animations>
                                        <Animation Duration="0:0:0.8" IterationCount="INFINITE">
                                            <KeyFrame Cue="0%">
                                                <Setter Property="RotateTransform.Angle" Value="0"/>
                                            </KeyFrame>
                                            <KeyFrame Cue="100%">
                                                <Setter Property="RotateTransform.Angle" Value="360"/>
                                            </KeyFrame>
                                        </Animation>
                                    </Style.Animations>
                                </Style>
                            </Ellipse.Styles>
                        </Ellipse>
                    </Panel>
                </Grid>
            </Button>

            <Button Content="&#x2190; Back to Login" Cursor="Hand" Height="44" FontSize="14" FontWeight="SemiBold"
                    Foreground="#374151" Margin="0,20,0,0" Click="BackToLogin_Click"
                    HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                    Classes="icon-btn"/>
        </StackPanel>
    </Grid>
</Window>

