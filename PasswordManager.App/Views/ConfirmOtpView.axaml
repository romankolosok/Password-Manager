<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        x:Class="PasswordManager.App.ConfirmOtpView"
        Height="300" Width="480"
        Background="White" WindowStartupLocation="CenterScreen"
        Title="Crypty - Confirm OTP">

    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,*" Margin="32">
        
        <StackPanel Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,24">
            <TextBlock Text="Enter Verification Code"
                       FontSize="20" FontWeight="SemiBold" Foreground="#111827"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="We sent a 6-digit code to your email"
                       FontSize="13" Foreground="#6B7280"
                       HorizontalAlignment="Center" Margin="0,6,0,0"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="8" Margin="16,0,16,8">
            <TextBox x:Name="Digit1Box"
                     Text="{Binding Digit1}"
                     MaxLength="1" TextAlignment="Center"
                     Width="36" MinWidth="0" Height="44" FontSize="20" FontWeight="Bold"
                     CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1.5"
                     Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <TextBox x:Name="Digit2Box"
                     Text="{Binding Digit2}"
                     MaxLength="1" TextAlignment="Center"
                     Width="36" MinWidth="0" Height="44" FontSize="20" FontWeight="Bold"
                     CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1.5"
                     Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <TextBox x:Name="Digit3Box"
                     Text="{Binding Digit3}"
                     MaxLength="1" TextAlignment="Center"
                     Width="36" MinWidth="0" Height="44" FontSize="20" FontWeight="Bold"
                     CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1.5"
                     Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <TextBox x:Name="Digit4Box"
                     Text="{Binding Digit4}"
                     MaxLength="1" TextAlignment="Center"
                     Width="36" MinWidth="0" Height="44" FontSize="20" FontWeight="Bold"
                     CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1.5"
                     Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <TextBox x:Name="Digit5Box"
                     Text="{Binding Digit5}"
                     MaxLength="1" TextAlignment="Center"
                     Width="36" MinWidth="0" Height="44" FontSize="20" FontWeight="Bold"
                     CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1.5"
                     Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <TextBox x:Name="Digit6Box"
                     Text="{Binding Digit6}"
                     MaxLength="1" TextAlignment="Center"
                     Width="36" MinWidth="0" Height="44" FontSize="20" FontWeight="Bold"
                     CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1.5"
                     Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <TextBox x:Name="Digit7Box"
                     Text="{Binding Digit7}"
                     MaxLength="1" TextAlignment="Center"
                     Width="36" MinWidth="0" Height="44" FontSize="20" FontWeight="Bold"
                     CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1.5"
                     Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
            <TextBox x:Name="Digit8Box"
                     Text="{Binding Digit8}"
                     MaxLength="1" TextAlignment="Center"
                     Width="36" MinWidth="0" Height="44" FontSize="20" FontWeight="Bold"
                     CornerRadius="8" BorderBrush="#D1D5DB" BorderThickness="1.5"
                     Padding="0" HorizontalContentAlignment="Center" VerticalContentAlignment="Center"/>
        </StackPanel>

        <!-- Error message -->
        <TextBlock Grid.Row="3"
                   Text="{Binding DisplayError}"
                   IsVisible="{Binding DisplayErrorVisible}"
                   Foreground="#DC2626" FontSize="12"
                   HorizontalAlignment="Center" Margin="0,4,0,12"/>

        <!-- Confirm button -->
        <Button Grid.Row="4"
                Height="44" CornerRadius="10"
                Command="{Binding ConfirmOtpCommand}"
                Classes="primary" HorizontalAlignment="Stretch"
                Margin="0,8,0,0">
            <Grid>
                <TextBlock Text="Confirm Code" VerticalAlignment="Center" HorizontalAlignment="Center"
                           FontWeight="SemiBold" FontSize="14"
                           IsVisible="{Binding !IsLoading}"/>
                <Panel IsVisible="{Binding IsLoading}" HorizontalAlignment="Center" VerticalAlignment="Center">
                    <Ellipse Width="24" Height="24" Stroke="White" StrokeThickness="3" Fill="Transparent"
                             StrokeDashArray="2,3" StrokeLineCap="Round"
                             RenderTransformOrigin="50%,50%">
                        <Ellipse.RenderTransform>
                            <RotateTransform/>
                        </Ellipse.RenderTransform>
                        <Ellipse.Styles>
                            <Style Selector="Ellipse">
                                <Style.Animations>
                                    <Animation Duration="0:0:0.8" IterationCount="INFINITE">
                                        <KeyFrame Cue="0%">
                                            <Setter Property="RotateTransform.Angle" Value="0"/>
                                        </KeyFrame>
                                        <KeyFrame Cue="100%">
                                            <Setter Property="RotateTransform.Angle" Value="360"/>
                                        </KeyFrame>
                                    </Animation>
                                </Style.Animations>
                            </Style>
                        </Ellipse.Styles>
                    </Ellipse>
                </Panel>
            </Grid>
        </Button>

        <!-- Resend link -->
        <StackPanel Grid.Row="5" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,16,0,0">
            <TextBlock Text="Didn't receive a code?" FontSize="13" Foreground="#6B7280"
                       VerticalAlignment="Center"/>
            <Button Content="Resend" Classes="hyperlink"
                    Command="{Binding ResendOtpCommand}"
                    FontSize="13" FontWeight="SemiBold" Foreground="#4F46E5"
                    Padding="4,0" Margin="2,0,0,0" VerticalAlignment="Center"/>
        </StackPanel>

    </Grid>
</Window>